           n_timepoints = m,
           low_CI = CI_FU2[4,1],
           high_CI = CI_FU2[4,2])

  results_FU2_df <- rbind(results_FU2_df, results_FU2)

}


results_MAIN_df <- results_MAIN_df %>% select(outcome, metabolite, everything())
results_FU1_df <- results_FU1_df %>% select(outcome, metabolite, everything())
results_FU2_df <- results_FU2_df %>% select(outcome, metabolite, everything())

write.csv(results_MAIN_df, file = "results/results_MAIN_metabolites_of_interest.csv", row.names=FALSE)
write.csv(results_FU1_df, file = "results/results_FU1_metabolites_of_interest.csv", row.names=FALSE)
write.csv(results_FU2_df, file = "results/results_FU2_metabolites_of_interest.csv", row.names=FALSE)
